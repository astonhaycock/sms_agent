# =============================================================================
# REQUIRED
# =============================================================================

# Security — used for JWT signing and encrypting stored credentials
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-CHANGE-THIS

# salt for password hashing and encryption
PASSWORD_HASHING_SALT=your-password-hashing-salt-here-CHANGE-THIS
ENCRYPTION_SALT=your-encryption-salt-here-CHANGE-THIS

# Twilio SMS
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# =============================================================================
# LLM — Local (Ollama, default)
# =============================================================================

# URL of your Ollama instance
OLLAMA_BASE_URL=http://localhost:11434

# Default model served by Ollama (used for all agents unless overridden per-user)
DEFAULT_LOCAL_MODEL=glm-4.7-flash

# Lightweight model used for Gmail summaries and low-resource tasks
GMAIL_LLM_MODEL=gemma3:4b

# Placeholder key required by smolagents when using Ollama for web search
ollama_api_key=ollama

# =============================================================================
# LLM — Cloud (optional — users can also supply their own keys via the web UI)
# =============================================================================

# OpenAI
OPENAI_API_KEY=sk-...
DEFAULT_OPENAI_MODEL=gpt-4o-mini

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini — also required for the web search agent
GEMINI_API_KEY=AIza...

# =============================================================================
# Google OAuth — required for Gmail agent
# =============================================================================

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# OAuth callback URL — must match what is registered in Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:8080/api/gmail/callback

# How often to poll Gmail for new emails from watched senders (seconds)
GMAIL_POLL_INTERVAL=300

# =============================================================================
# Langfuse observability (optional — disable by setting LANGFUSE_ENABLED=false)
# =============================================================================

LANGFUSE_ENABLED=true
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=http://localhost:3001

# =============================================================================
# Web / API
# =============================================================================

# Comma-separated allowed CORS origins
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# "development" or "production"
ENVIRONMENT=development

# Path to the SQLite database file
DATABASE_PATH=offgrid_agent.db

# JWT access token lifetime (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Enable request rate limiting
RATE_LIMIT_ENABLED=true
